{
  "name": "@arkite/ui",
  "version": "0.1.0",
  "description": "Production-ready components for SaaS admin panels. Built on shadcn/ui.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./src/styles/index.css",
    "./tailwind": {
      "import": {
        "types": "./dist/tailwind-preset.d.ts",
        "default": "./dist/tailwind-preset.js"
      },
      "require": {
        "types": "./dist/tailwind-preset.d.cts",
        "default": "./dist/tailwind-preset.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "lucide-react": "^0.460.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.15",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18",
    "zustand": "^5.0.1"
  },
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/arkite-ui.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "saas",
    "admin",
    "dashboard",
    "tailwindcss",
    "multi-tenant"
  ],
  "author": "",
  "bugs": {
    "url": "https://github.com/your-org/arkite-ui/issues"
  },
  "homepage": "https://github.com/your-org/arkite-ui#readme",
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
