{
  "name": "@arkite/ui",
  "version": "0.3.1",
  "description": "Production-ready components for SaaS admin panels. Built on shadcn/ui.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./src/styles/index.css",
    "./motion": {
      "import": {
        "types": "./dist/motion.d.ts",
        "default": "./dist/motion.js"
      },
      "require": {
        "types": "./dist/motion.d.cts",
        "default": "./dist/motion.cjs"
      }
    },
    "./tailwind": {
      "import": {
        "types": "./dist/tailwind-preset.d.ts",
        "default": "./dist/tailwind-preset.js"
      },
      "require": {
        "types": "./dist/tailwind-preset.d.cts",
        "default": "./dist/tailwind-preset.cjs"
      }
    }
  },
  "bin": {
    "arkite-ui": "./cli/init.mjs"
  },
  "files": [
    "dist",
    "src/styles",
    "cli"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "300 kB"
    },
    {
      "path": "dist/motion.js",
      "limit": "10 kB"
    },
    {
      "path": "dist/tailwind-preset.js",
      "limit": "10 kB"
    }
  ],
  "peerDependencies": {
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "cmdk": "^1.0.0",
    "framer-motion": "^10.0.0 || ^11.0.0 || ^12.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@radix-ui/react-dropdown-menu": {
      "optional": true
    },
    "@radix-ui/react-popover": {
      "optional": true
    },
    "@radix-ui/react-tooltip": {
      "optional": true
    },
    "@tanstack/react-virtual": {
      "optional": true
    },
    "cmdk": {
      "optional": true
    },
    "framer-motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.4",
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-onboarding": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "chromatic": "^15.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "framer-motion": "^12.35.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.460.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "size-limit": "^12.0.1",
    "storybook": "^10.2.16",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "zustand": "^5.0.1"
  },
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/foson.co/arkite-ui.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "saas",
    "admin",
    "dashboard",
    "tailwindcss",
    "multi-tenant"
  ],
  "author": "",
  "bugs": {
    "url": "https://gitlab.com/foson.co/arkite-ui/-/issues"
  },
  "homepage": "https://gitlab.com/foson.co/arkite-ui#readme",
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
